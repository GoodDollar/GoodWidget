{
  "name": "@goodwidget/embed",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./appkit-provider": {
      "types": "./dist/appkitProvider.d.ts",
      "import": "./dist/appkitProvider.js",
      "require": "./dist/appkitProvider.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@goodwidget/core": "workspace:*",
    "@goodwidget/ui": "workspace:*",
    "@reown/appkit": "^1.8.22",
    "@r2wc/react-to-web-component": "^2.0.3"
  },
  "devDependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  }
}
