    "dev": "tsup --watch",
    "lint": "eslint src/",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.76.0",
    "@react-native-clipboard/clipboard": ">=1.14.0"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    },
    "@react-native-clipboard/clipboard": {
      "optional": true
    }
  },
  "dependencies": {
    "@tamagui/animations-react-native": "^1.121.0",
    "@tamagui/core": "1.121.0",
    "@tamagui/themes": "1.121.0",
    "tamagui": "1.121.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "react-native": "0.76.9",
    "react-native-web": "^0.19.13",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  }
